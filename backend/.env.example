# DownAria-API — Local Development
# NOTE: Production uses PORT=10000 (set via render.yaml / Render dashboard)

PORT=8081
ENV=development

# CORS — development origins only
# Production: set ALLOWED_ORIGINS in Render dashboard or render.yaml
ALLOWED_ORIGINS=http://127.0.0.1:3001,http://localhost:3001
WEB_INTERNAL_SHARED_SECRET=dev-secret-change-in-production

# Performance
UPSTREAM_TIMEOUT_MS=10000
MERGE_ENABLED=true
GLOBAL_RATE_LIMIT_WINDOW=60/1m
MAX_DOWNLOAD_SIZE_MB=1024

# Stats (optional)
STATS_PERSIST_ENABLED=false
STATS_PERSIST_FILE_PATH=./data/public_stats.json
STATS_PERSIST_FLUSH_INTERVAL_MS=5000

# Cache
CACHE_EXTRACTION_TTL=5m
CACHE_PROXY_HEAD_TTL=45s
