# ═══════════════════════════════════════════════════════════════
# FRONTEND Environment — copy to .env.local for local dev
# ═══════════════════════════════════════════════════════════════

# ── App URLs ─────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:8081

# Backend URL (server-side ONLY — no NEXT_PUBLIC prefix)
# Drives Next.js rewrites for auto-connect to backend
BACKEND_URL=http://localhost:8081

# ── Production (set in Vercel Dashboard) ─────────────────────────
# NEXT_PUBLIC_BASE_URL=https://downloader.nafij.me
# NEXT_PUBLIC_API_URL=https://nafijthepro-downloader.onrender.com
# BACKEND_URL=https://nafijthepro-downloader.onrender.com

# ── Supabase (required for auth) ─────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# ── Push Notifications (optional) ────────────────────────────────
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=BPxxx...

# ── Logging (optional) ───────────────────────────────────────────
LOG_LEVEL=info

# ═══════════════════════════════════════════════════════════════
# NEVER store in frontend: SUPABASE_SERVICE_ROLE_KEY, VAPID_PRIVATE_KEY
# ═══════════════════════════════════════════════════════════════
