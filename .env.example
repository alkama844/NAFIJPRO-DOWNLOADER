# ═════════════════════════════════════════════════════════════════════════════
# NAFIJPRO-DOWNLOADER - Complete Environment Configuration
# ═════════════════════════════════════════════════════════════════════════════
# Copy sections to backend/.env and fauntend/.env.local for local development
# For production: Set in Render dashboard (backend) and Vercel dashboard (frontend)
# ═════════════════════════════════════════════════════════════════════════════

# ═════════════════════════════════════════════════════════════════════════════
# SHARED VARIABLES (Both Backend & Frontend)
# ═════════════════════════════════════════════════════════════════════════════

ALLOWED_ORIGINS=https://downloader.nafij.me,https://downloader-nafijrahaman.vercel.app
BACKEND_URL=https://nafijpro-downloader.onrender.com
CACHE_EXTRACTION_TTL=5m
CACHE_PROXY_HEAD_TTL=45s
ENV=development
EXTRACTION_MAX_RETRIES=3
GLOBAL_RATE_LIMIT_WINDOW=60/1m
MAX_DOWNLOAD_SIZE_MB=300
MERGE_ENABLED=true
PORT=10000
PUBLIC_BASE_URL=https://nafijpro-downloader.onrender.com
STATS_PERSIST_ENABLED=false
STATS_PERSIST_FILE_PATH=./data/public_stats.json
STATS_PERSIST_FLUSH_INTERVAL_MS=5000
UPSTREAM_TIMEOUT_MS=10000
WEB_INTERNAL_SHARED_SECRET=nafijrahaman_7f3c9d8a4b2e6f1a9c0d5e8b7a3f2c1d

# ═════════════════════════════════════════════════════════════════════════════
# BACKEND CONFIGURATION (backend/.env)
# ═════════════════════════════════════════════════════════════════════════════

# Server Configuration
PORT=10000
ENV=development
PUBLIC_BASE_URL=https://nafijpro-downloader.onrender.com

# Security: BFF Shared Secret
WEB_INTERNAL_SHARED_SECRET=nafijrahaman_7f3c9d8a4b2e6f1a9c0d5e8b7a3f2c1d

# CORS: Frontend origin(s)
ALLOWED_ORIGINS=https://downloader.nafij.me,https://downloader-nafijrahaman.vercel.app

# Media Extraction & Processing
MERGE_ENABLED=true
UPSTREAM_TIMEOUT_MS=10000
MAX_DOWNLOAD_SIZE_MB=300
EXTRACTION_MAX_RETRIES=3

# Rate Limiting (format: "limit/duration")
GLOBAL_RATE_LIMIT_WINDOW=60/1m

# Result Caching
CACHE_EXTRACTION_TTL=5m
CACHE_PROXY_HEAD_TTL=45s

# Stats Persistence (optional)
STATS_PERSIST_ENABLED=false
STATS_PERSIST_FILE_PATH=./data/public_stats.json
STATS_PERSIST_FLUSH_INTERVAL_MS=5000

# ═════════════════════════════════════════════════════════════════════════════
# FRONTEND CONFIGURATION (fauntend/.env.local)
# ═════════════════════════════════════════════════════════════════════════════

# Public URLs (visible to browser)
NEXT_PUBLIC_BASE_URL=https://downloader-nafijrahaman.vercel.app
NEXT_PUBLIC_API_URL=https://nafijpro-downloader.onrender.com

# Backend URL (server-side only - drives Next.js rewrites)
BACKEND_URL=https://nafijpro-downloader.onrender.com

# Security: BFF Shared Secret (must match backend)
WEB_INTERNAL_SHARED_SECRET=nafijrahaman_7f3c9d8a4b2e6f1a9c0d5e8b7a3f2c1d

# Supabase Authentication
NEXT_PUBLIC_SUPABASE_URL=https://wbfjtbbvymswtsqodusy.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_ojMo8BK-7_pfVkNbjmf8lg_jYq3_TRt

# ═════════════════════════════════════════════════════════════════════════════
# NOTES
# ═════════════════════════════════════════════════════════════════════════════
# - NEVER commit .env files to git (use .gitignore)
# - WEB_INTERNAL_SHARED_SECRET must match exactly between frontend & backend
# - NEXT_PUBLIC_* variables are embedded in browser bundle (public-safe only)
# - For production: Set in Render dashboard (backend) and Vercel dashboard (frontend)
# - Supabase keys are optional but required for authentication features
